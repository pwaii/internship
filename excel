/**
 * Excel Office Script
 * Fast formula-based Final Data builder.
 *
 * Input sheets:
 * - Product Master: Company, Product Name, Index, Index Code, PR, Formula, Volatility
 * - Cohort Schedule: Product Name, Cohort No., Cohort Start Date, Cohort End Date
 * - Index Price: Date + one column per Index Code
 * - FX Rate: Date/Month + USD/THB
 */
function main(workbook: ExcelScript.Workbook): string {
  const PRODUCT_SHEET = "Product Master";
  const COHORT_SHEET = "Cohort Schedule";
  const INDEX_SHEET = "Index Price";
  const FX_SHEET = "FX Rate";
  const FINAL_SHEET = "Final Data";
  const MAX_ROWS_PER_RUN = 8000;
  const WRITE_CHUNK_ROWS = 200;
  const EXCEL_MAX_ROWS = 1048576;

  const productWs = mustGetSheet(workbook, PRODUCT_SHEET);
  const cohortWs = mustGetSheet(workbook, COHORT_SHEET);
  const indexWs = mustGetSheet(workbook, INDEX_SHEET);
  const fxWs = mustGetSheet(workbook, FX_SHEET);

  const productData = getUsedValues(productWs);
  const cohortData = getUsedValues(cohortWs);
  const indexData = getUsedValues(indexWs);
  const fxData = getUsedValues(fxWs);

  const productHeaders = headerMap(productData[0]);
  const cohortHeaders = headerMap(cohortData[0]);
  const indexHeaders = headerMap(indexData[0]);
  const fxHeaders = headerMap(fxData[0]);

  const pCompany = firstHeader(productHeaders, ["COMPANY", "COMPANYNAME"]);
  const pProduct = requiredHeader(productHeaders, ["PRODUCTNAME"], PRODUCT_SHEET);
  const pIndex = requiredHeader(productHeaders, ["INDEX"], PRODUCT_SHEET);
  const pIndexCode = requiredHeader(productHeaders, ["INDEXCODE"], PRODUCT_SHEET);
  const pPR = requiredHeader(productHeaders, ["PR"], PRODUCT_SHEET);
  const pFormula = requiredHeader(productHeaders, ["FORMULA"], PRODUCT_SHEET);
  const pVolatility = firstHeader(productHeaders, ["VOLATILITY"]);

  const cProduct = requiredHeader(cohortHeaders, ["PRODUCTNAME"], COHORT_SHEET);
  const cCohortNo = requiredHeader(cohortHeaders, ["COHORTNO"], COHORT_SHEET);
  const cStart = requiredHeader(cohortHeaders, ["COHORTSTARTDATE"], COHORT_SHEET);
  const cEnd = requiredHeader(cohortHeaders, ["COHORTENDDATE"], COHORT_SHEET);

  const iDate = requiredHeader(indexHeaders, ["DATE"], INDEX_SHEET);
  const fDate = firstHeader(fxHeaders, ["DATE", "MONTH"]) ?? 0;
  const fRate = firstHeader(fxHeaders, ["USDTHB", "USDTH"]) ?? 1;

  const finalWs = workbook.getWorksheet(FINAL_SHEET);
  if (!finalWs) {
    throw new Error(`Missing sheet: ${FINAL_SHEET}. Please create a blank sheet named "${FINAL_SHEET}" before running this script.`);
  }

  const headers = [
    "Company",
    "ProductName",
    "IndexName",
    "IndexCode",
    "CohortNo",
    "CohortStartDate",
    "CohortEndDate",
    "Date",
    "Price",
    "IndexBaseValue",
    "IndexGrowth",
    "FXRate",
    "FXBaseRate",
    "FXGrowth",
    "PR",
    "Principal",
    "ProductReturn",
    "ProductValue",
    "Volatility",
    "Formula"
  ];

  const resetRequested = cleanKey(finalWs.getRange("U4").getValue()) === "RESET";
  const statusValue = cleanKey(finalWs.getRange("U2").getValue());
  if (statusValue === "DONE" && !resetRequested) {
    return "Final Data is already complete. Type RESET in Final Data!U4 if you want to rebuild from scratch.";
  }

  const savedRowCount = toNumber(finalWs.getRange("U1").getValue()) ?? 0;
  const savedCohortRow = toNumber(finalWs.getRange("U2").getValue());
  const savedDateOffset = toNumber(finalWs.getRange("U3").getValue()) ?? 0;
  const isResume = !resetRequested && savedRowCount > 0 && savedCohortRow !== null && savedCohortRow >= 1;

  let existingRows = isResume ? Math.floor(savedRowCount) : 0;
  let startCohortRow = isResume ? Math.floor(savedCohortRow) : 1;
  let startDateOffset = isResume ? Math.floor(savedDateOffset) : 0;

  if (!isResume) {
    clearFinalDataArea(finalWs);
    finalWs.getRangeByIndexes(0, 0, 1, headers.length).setValues([headers]);
    finalWs.getRange("U1:U4").clear(ExcelScript.ClearApplyTo.contents);
  }

  const productRows = buildProductRows(productData, pProduct);
  const maxCohortNoByProduct = buildMaxCohortNoByProduct(cohortData, cProduct, cCohortNo);
  const indexHeaderCodes = indexData[0].map(v => cleanIndexCode(v));
  const indexDateRows = buildDateRows(indexData, iDate);
  const fxDateRows = buildDateRows(fxData, fDate);

  const rows: (string | number | boolean)[][] = [];
  let nextCohortRow: number | string = "DONE";
  let nextDateOffset = 0;
  let reachedLimit = false;

  for (let c = startCohortRow; c < cohortData.length; c++) {
    const productName = text(cohortData[c][cProduct]);
    if (!productName) continue;

    const productRow = productRows.get(cleanKey(productName));
    if (productRow === undefined) continue;

    const startSerial = toExcelSerial(cohortData[c][cStart]);
    const endSerial = toExcelSerial(cohortData[c][cEnd]);
    if (startSerial === null || endSerial === null || endSerial < startSerial) continue;

    const indexCode = cleanIndexCode(productData[productRow][pIndexCode]);
    const indexCol = indexHeaderCodes.findIndex(code => code === indexCode);
    if (indexCol < 0) continue;

    const periodRowsAll = getDateRowsFromStart(indexDateRows, startSerial).filter(d => {
      const price = toNumber(indexData[d.row][indexCol]);
      return price !== null;
    });
    const cohortNoNumber = toNumber(cohortData[c][cCohortNo]);
    const maxCohortNo = maxCohortNoByProduct.get(cleanKey(productName));
    const cohortAge = cohortNoNumber !== null && maxCohortNo !== undefined ? maxCohortNo - cohortNoNumber : cohortData.length - c - 1;
    const periodRows = samplePeriodRows(periodRowsAll, cohortAge);
    if (periodRows.length === 0) continue;

    const productExcelRow = productRow + 1;
    const cohortExcelRow = c + 1;
    const baseIndexExcelRow = periodRows[0].row + 1;
    const baseFxRow: number | undefined = findFxRowOnOrBefore(startSerial, fxDateRows);
    const formulaText = text(productData[productRow][pFormula]) || "FXGrowth * PR * MAX(0, IndexGrowth)";
    const companyValue = pCompany === null ? "MTL" : text(productData[productRow][pCompany]);
    const indexNameValue = text(productData[productRow][pIndex]);
    const indexCodeValue = text(productData[productRow][pIndexCode]);
    const cohortNoValue = cohortData[c][cCohortNo];
    const prValue = normalizeRate(productData[productRow][pPR]);
    const volatilityValue = pVolatility === null ? "" : normalizeRate(productData[productRow][pVolatility]);

    const dateStart = c === startCohortRow ? startDateOffset : 0;
    for (let d = dateStart; d < periodRows.length; d++) {
      const item = periodRows[d];
      const finalRow = existingRows + rows.length + 2;
      const indexExcelRow = item.row + 1;
      const fxExcelRow: number | undefined = findFxRowOnOrBefore(item.serial, fxDateRows);
      const baseFxExcelRow: number | undefined = baseFxRow ?? fxExcelRow;

      rows.push([
        companyValue,
        productName,
        indexNameValue,
        indexCodeValue,
        cohortNoValue,
        excelSerialToIsoDate(startSerial),
        excelSerialToIsoDate(endSerial),
        excelSerialToIsoDate(item.serial),
        `=${ref(INDEX_SHEET, indexExcelRow, indexCol + 1)}`,
        `=${ref(INDEX_SHEET, baseIndexExcelRow, indexCol + 1)}`,
        `=IFERROR(I${finalRow}/J${finalRow}-1,"")`,
        fxExcelRow === undefined ? `=""` : `=${ref(FX_SHEET, fxExcelRow + 1, fRate + 1)}`,
        baseFxExcelRow === undefined ? `=""` : `=${ref(FX_SHEET, baseFxExcelRow + 1, fRate + 1)}`,
        `=IFERROR(L${finalRow}/M${finalRow},"")`,
        prValue,
        `=100`,
        makeProductReturnFormula(formulaText, finalRow),
        `=IFERROR(100*(1+Q${finalRow}),"")`,
        volatilityValue,
        formulaText
      ]);

      if (rows.length >= MAX_ROWS_PER_RUN) {
        nextCohortRow = c;
        nextDateOffset = d + 1;
        reachedLimit = true;
        break;
      }
    }

    if (reachedLimit) break;
  }

  if (reachedLimit === false) {
    nextCohortRow = "DONE";
    nextDateOffset = 0;
  }

  if (rows.length > 0) {
    if (existingRows + rows.length + 1 > EXCEL_MAX_ROWS) {
      throw new Error(`Final Data would exceed Excel row limit. Existing rows: ${existingRows}, new rows: ${rows.length}.`);
    }
    setFinalDataByBlocks(finalWs, existingRows + 1, rows, WRITE_CHUNK_ROWS);
  }

  const totalRows = existingRows + rows.length;
  finalWs.getRange("U1").setValue(totalRows);
  finalWs.getRange("U2").setValue(nextCohortRow);
  finalWs.getRange("U3").setValue(nextDateOffset);
  finalWs.getRange("U4").setValue(nextCohortRow === "DONE" ? "COMPLETE" : "RUN AGAIN");
  finalWs.getRange("A1:T1").getFormat().getFont().setBold(true);

  return nextCohortRow === "DONE"
    ? `Complete. Final Data rows: ${totalRows}.`
    : `Paused safely. Added ${rows.length} rows. Total rows: ${totalRows}. Run the script again to continue from cohort sheet row ${nextCohortRow}, date offset ${nextDateOffset}.`;
}

function mustGetSheet(workbook: ExcelScript.Workbook, name: string): ExcelScript.Worksheet {
  const ws = workbook.getWorksheet(name);
  if (!ws) throw new Error(`Missing sheet: ${name}`);
  return ws;
}

function getUsedValues(ws: ExcelScript.Worksheet): (string | number | boolean)[][] {
  const range = ws.getUsedRange(true);
  if (!range) throw new Error(`Sheet has no data: ${ws.getName()}`);
  return range.getValues() as (string | number | boolean)[][];
}

function clearFinalDataArea(ws: ExcelScript.Worksheet) {
  const marker = Number(ws.getRange("U1").getValue());
  const used = ws.getUsedRange(true);
  const fallbackRows = used ? Math.min(Math.max(used.getRowCount(), 1), 2000) : 1;
  const rowCount = Math.min(Number.isFinite(marker) && marker > 0 ? marker + 1 : fallbackRows, 1048576);

  for (let start = 0; start < rowCount; start += 500) {
    const count = Math.min(500, rowCount - start);
    if (count <= 0) break;
    ws.getRangeByIndexes(start, 0, count, 20).clear(ExcelScript.ClearApplyTo.contents);
  }
}

function headerMap(row: (string | number | boolean)[]): Map<string, number> {
  const m = new Map<string, number>();
  row.forEach((v, i) => m.set(cleanHeader(v), i));
  return m;
}

function requiredHeader(map: Map<string, number>, names: string[], sheetName: string): number {
  const found = firstHeader(map, names);
  if (found === null) throw new Error(`Missing required header on ${sheetName}: ${names.join(" / ")}`);
  return found;
}

function firstHeader(map: Map<string, number>, names: string[]): number | null {
  for (const n of names) {
    const v = map.get(cleanHeader(n));
    if (v !== undefined) return v;
  }
  return null;
}

function cleanHeader(v: unknown): string {
  return String(v ?? "").trim().toUpperCase().replace(/[\s._\-()/#: '"\u00A0]/g, "");
}

function cleanKey(v: unknown): string {
  return String(v ?? "").trim().toUpperCase();
}

function cleanIndexCode(v: unknown): string {
  let s = cleanHeader(v);
  if (s.endsWith("INDEX")) s = s.substring(0, s.length - 5);
  return s;
}

function text(v: unknown): string {
  return String(v ?? "").trim();
}

function toNumber(v: unknown): number | null {
  if (typeof v === "number" && isFinite(v)) return v;
  const n = Number(String(v ?? "").replace(/[%~,]/g, "").trim());
  return isFinite(n) ? n : null;
}

function normalizeRate(v: unknown): number | string {
  const n = toNumber(v);
  if (n === null) return "";
  return n > 1 ? n / 100 : n;
}

function toExcelSerial(v: unknown): number | null {
  if (typeof v === "number" && isFinite(v)) return v;
  const raw = String(v ?? "").trim();
  const parts = raw.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
  const d = parts ? new Date(Number(parts[3]), Number(parts[2]) - 1, Number(parts[1])) : new Date(raw);
  if (isNaN(d.getTime())) return null;
  return d.getTime() / 86400000 + 25569;
}

function excelSerialToIsoDate(serial: number): string {
  const d = excelSerialToDate(serial);
  const year = d.getUTCFullYear();
  const month = String(d.getUTCMonth() + 1).padStart(2, "0");
  const day = String(d.getUTCDate()).padStart(2, "0");
  return `${year}-${month}-${day}`;
}

function buildProductRows(data: (string | number | boolean)[][], productCol: number): Map<string, number> {
  const m = new Map<string, number>();
  for (let r = 1; r < data.length; r++) {
    const key = cleanKey(data[r][productCol]);
    if (key && !m.has(key)) m.set(key, r);
  }
  return m;
}

function buildMaxCohortNoByProduct(
  data: (string | number | boolean)[][],
  productCol: number,
  cohortNoCol: number
): Map<string, number> {
  const m = new Map<string, number>();
  for (let r = 1; r < data.length; r++) {
    const key = cleanKey(data[r][productCol]);
    const cohortNo = toNumber(data[r][cohortNoCol]);
    if (!key || cohortNo === null) continue;
    const current = m.get(key);
    if (current === undefined || cohortNo > current) m.set(key, cohortNo);
  }
  return m;
}

function buildDateRows(data: (string | number | boolean)[][], dateCol: number): { row: number; serial: number }[] {
  const rows: { row: number; serial: number }[] = [];
  for (let r = 1; r < data.length; r++) {
    const serial = toExcelSerial(data[r][dateCol]);
    if (serial !== null) rows.push({ row: r, serial });
  }
  rows.sort((a, b) => a.serial - b.serial);
  return rows;
}

function getDateRowsFromStart(
  rows: { row: number; serial: number }[],
  startSerial: number
): { row: number; serial: number }[] {
  const result: { row: number; serial: number }[] = [];
  for (const item of rows) {
    if (item.serial < startSerial) continue;
    result.push(item);
  }
  return result;
}

function samplePeriodRows(
  rows: { row: number; serial: number }[],
  cohortAge: number
): { row: number; serial: number }[] {
  if (rows.length <= 2 || cohortAge <= 6) return rows;

  if (cohortAge > 30) {
    return uniqueDateRows([
      rows[0],
      rows[rows.length - 1]
    ]);
  }

  if (cohortAge > 12) {
    return uniqueDateRows([
      rows[0],
      rows[Math.floor((rows.length - 1) / 2)],
      rows[rows.length - 1]
    ]);
  }

  const selected: { row: number; serial: number }[] = [];
  const seen = new Set<number>();

  for (const item of rows) {
    const key = fourPointMonthlySamplingKey(item.serial);
    if (!seen.has(key)) {
      seen.add(key);
      selected.push(item);
    }
  }

  const first = rows[0];
  const last = rows[rows.length - 1];
  if (selected.length === 0 || selected[0].serial !== first.serial) selected.unshift(first);
  if (selected[selected.length - 1].serial !== last.serial) selected.push(last);

  return selected;
}

function uniqueDateRows(rows: { row: number; serial: number }[]): { row: number; serial: number }[] {
  const selected: { row: number; serial: number }[] = [];
  const seen = new Set<number>();
  for (const item of rows) {
    if (!seen.has(item.serial)) {
      seen.add(item.serial);
      selected.push(item);
    }
  }
  return selected;
}

function fourPointMonthlySamplingKey(serial: number): number {
  const date = excelSerialToDate(serial);
  const year = date.getUTCFullYear();
  const month = date.getUTCMonth() + 1;
  const day = date.getUTCDate();
  const monthKey = year * 100 + month;
  const bucket = day <= 7 ? 1 : day <= 14 ? 2 : day <= 21 ? 3 : 4;
  return monthKey * 10 + bucket;
}

function excelSerialToDate(serial: number): Date {
  const utcMs = Math.round((serial - 25569) * 86400000);
  return new Date(utcMs);
}

function findFxRowOnOrBefore(serial: number, fxDateRows: { row: number; serial: number }[]): number | undefined {
  let best: number | undefined = undefined;
  for (const item of fxDateRows) {
    if (item.serial <= serial) {
      best = item.row;
    } else {
      break;
    }
  }
  return best;
}

function makeProductReturnFormula(rawFormula: string, row: number): string {
  let expr = rawFormula.trim();
  if (expr.includes("=")) expr = expr.substring(expr.indexOf("=") + 1);
  if (!expr) expr = "FXGrowth * PR * MAX(0, IndexGrowth)";

  // In Final Data, IndexGrowth is already Price / IndexBaseValue - 1.
  // If a product formula says IndexGrowth - 1, it is usually describing
  // IndexRatio - 1, so normalize that wording back to IndexGrowth.
  expr = expr
    .replace(/\bIndexGrowth\b\s*-\s*1/gi, "IndexGrowth")
    .replace(/\bIndexGrowth\b\s*-\s*100%/gi, "IndexGrowth")
    .replace(/\bIndexReturn\b/gi, "IndexGrowth");

  expr = expr
    .replace(/\bPrincipal\b/gi, `P${row}`)
    .replace(/\bFXGrowth\b/gi, `N${row}`)
    .replace(/\bPR\b/gi, `O${row}`)
    .replace(/\bIndexGrowth\b/gi, `K${row}`)
    .replace(/\bPrice\b/gi, `I${row}`)
    .replace(/\bIndexBaseValue\b/gi, `J${row}`)
    .replace(/\bFXRate\b/gi, `L${row}`)
    .replace(/\bFXBaseRate\b/gi, `M${row}`);

  const hasPrincipal = /P\d+/.test(expr);
  return hasPrincipal ? `=IFERROR((${expr})/P${row},"")` : `=IFERROR(${expr},"")`;
}

function ref(sheetName: string, row: number, col: number): string {
  return `'${sheetName}'!${colLetter(col)}${row}`;
}

function setFinalDataByBlocks(
  ws: ExcelScript.Worksheet,
  startRow: number,
  data: (string | number | boolean)[][],
  chunkSize: number
) {
  if (data.length === 0) return;
  const maxRows = 1048576;

  for (let start = 0; start < data.length; start += chunkSize) {
    const chunk = data.slice(start, start + chunkSize);
    const targetRow = startRow + start;
    if (targetRow < 0 || targetRow + chunk.length > maxRows) {
      throw new Error(`Invalid write range at row ${targetRow + 1}, rows ${chunk.length}.`);
    }

    setValueBlock(ws, targetRow, 0, chunk, 0, 8);
    setFormulaBlock(ws, targetRow, 8, chunk, 8, 6);
    setValueBlock(ws, targetRow, 14, chunk, 14, 2);
    setFormulaBlock(ws, targetRow, 16, chunk, 16, 2);
    setValueBlock(ws, targetRow, 18, chunk, 18, 2);
  }
}

function setValueBlock(
  ws: ExcelScript.Worksheet,
  targetRow: number,
  targetCol: number,
  rows: (string | number | boolean)[][],
  sourceCol: number,
  colCount: number
) {
  const values = rows.map(row => row.slice(sourceCol, sourceCol + colCount).map(value => safeCellValue(value)));
  ws.getRangeByIndexes(targetRow, targetCol, rows.length, colCount).setValues(values);
}

function setFormulaBlock(
  ws: ExcelScript.Worksheet,
  targetRow: number,
  targetCol: number,
  rows: (string | number | boolean)[][],
  sourceCol: number,
  colCount: number
) {
  const formulas = rows.map(row => row.slice(sourceCol, sourceCol + colCount).map(value => String(value ?? "")));
  ws.getRangeByIndexes(targetRow, targetCol, rows.length, colCount).setFormulas(formulas);
}

function safeCellValue(value: string | number | boolean): string | number | boolean {
  if (value === undefined || value === null) return "";
  if (typeof value === "number") return Number.isFinite(value) ? value : "";
  return value;
}

function colLetter(col: number): string {
  let s = "";
  while (col > 0) {
    const mod = (col - 1) % 26;
    s = String.fromCharCode(65 + mod) + s;
    col = Math.floor((col - mod) / 26);
  }
  return s;
}
