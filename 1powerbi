{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "MTL clean red dashboard with calendar x-axis and dynamic y-axis padded by 5 percentage points.",
  "background": "#F4F8FB",
  "width": 1500,
  "height": 900,
  "padding": 0,
  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": true
  },
  "data": [
    {
      "name": "dataset"
    },
    {
      "name": "chartData",
      "source": "dataset",
      "transform": [
        {
          "type": "formula",
          "expr": "toNumber(datum.Price)",
          "as": "NumericPrice"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.IndexBaseValue)",
          "as": "NumericBase"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.PR) > 1 ? toNumber(datum.PR) / 100 : toNumber(datum.PR)",
          "as": "NumericPR"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.FloorRate) > 1 ? toNumber(datum.FloorRate) / 100 : toNumber(datum.FloorRate)",
          "as": "NumericFloor"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.CapRate) > 1 ? toNumber(datum.CapRate) / 100 : toNumber(datum.CapRate)",
          "as": "NumericCap"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.Principal) > 0 ? toNumber(datum.Principal) : 100",
          "as": "NumericPrincipal"
        },
        {
          "type": "formula",
          "expr": "isDate(datum.Date) ? time(datum.Date) : isNumber(datum.Date) ? (datum.Date > 1000000000 ? datum.Date : (datum.Date - 25569) * 86400000) : time(toDate(datum.Date))",
          "as": "DateKey"
        },
        {
          "type": "filter",
          "expr": "isFinite(datum.NumericPrice) && isFinite(datum.NumericBase) && datum.NumericBase > 0 && isFinite(datum.DateKey)"
        },
        {
          "type": "formula",
          "expr": "datum.NumericPrice / datum.NumericBase * 100",
          "as": "DisplayIndex"
        },
        {
          "type": "formula",
          "expr": "datum.DisplayIndex / 100 - 1",
          "as": "IndexReturnCalc"
        },
        {
          "type": "formula",
          "expr": "upper(toString(datum.FormulaType || 'PR_ONLY'))",
          "as": "FormulaKey"
        },
        {
          "type": "formula",
          "expr": "datum.FormulaKey === 'ABS_PR' ? min(max(abs(datum.IndexReturnCalc) * datum.NumericPR, datum.NumericFloor), datum.NumericCap) : datum.FormulaKey === 'CAP_FLOOR' ? min(max(datum.IndexReturnCalc * datum.NumericPR, datum.NumericFloor), datum.NumericCap) : max(datum.IndexReturnCalc * datum.NumericPR, datum.NumericFloor)",
          "as": "ProductReturnCalc"
        },
        {
          "type": "formula",
          "expr": "100 * (1 + datum.ProductReturnCalc)",
          "as": "DisplayProduct"
        },
        {
          "type": "collect",
          "sort": {
            "field": "DateKey",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "RowIndex"
          ]
        },
        {
          "type": "formula",
          "expr": "isDate(datum.CohortStartDate) ? time(datum.CohortStartDate) : isNumber(datum.CohortStartDate) ? (datum.CohortStartDate > 1000000000 ? datum.CohortStartDate : (datum.CohortStartDate - 25569) * 86400000) : time(toDate(datum.CohortStartDate))",
          "as": "CohortStartKey"
        },
        {
          "type": "formula",
          "expr": "isFinite(datum.CohortStartKey) ? datum.CohortStartKey + (datum.RowIndex - 1) * 7 * 86400000 : datum.DateKey",
          "as": "AxisDateKey"
        }
      ]
    },
    {
      "name": "dynamicYDomain",
      "source": "chartData",
      "transform": [
        {
          "type": "aggregate",
          "ops": [
            "min",
            "max",
            "min",
            "max"
          ],
          "fields": [
            "DisplayIndex",
            "DisplayIndex",
            "DisplayProduct",
            "DisplayProduct"
          ],
          "as": [
            "MinIndex",
            "MaxIndex",
            "MinProduct",
            "MaxProduct"
          ]
        },
        {
          "type": "formula",
          "expr": "min(datum.MinIndex, datum.MinProduct)",
          "as": "ActualMin"
        },
        {
          "type": "formula",
          "expr": "max(datum.MaxIndex, datum.MaxProduct)",
          "as": "ActualMax"
        },
        {
          "type": "formula",
          "expr": "floor((datum.ActualMin - 5) / 1) * 1",
          "as": "DomainMin"
        },
        {
          "type": "formula",
          "expr": "ceil((datum.ActualMax + 5) / 1) * 1",
          "as": "DomainMax"
        },
        {
          "type": "formula",
          "expr": "datum.DomainMax - datum.DomainMin",
          "as": "Span"
        }
      ]
    },
    {
      "name": "yTickData",
      "source": "dynamicYDomain",
      "transform": [
        {
          "type": "formula",
          "expr": "datum.DomainMin",
          "as": "Tick0"
        },
        {
          "type": "formula",
          "expr": "datum.DomainMin + datum.Span / 6",
          "as": "Tick1"
        },
        {
          "type": "formula",
          "expr": "datum.DomainMin + datum.Span * 2 / 6",
          "as": "Tick2"
        },
        {
          "type": "formula",
          "expr": "datum.DomainMin + datum.Span * 3 / 6",
          "as": "Tick3"
        },
        {
          "type": "formula",
          "expr": "datum.DomainMin + datum.Span * 4 / 6",
          "as": "Tick4"
        },
        {
          "type": "formula",
          "expr": "datum.DomainMin + datum.Span * 5 / 6",
          "as": "Tick5"
        },
        {
          "type": "formula",
          "expr": "datum.DomainMax",
          "as": "Tick6"
        },
        {
          "type": "fold",
          "fields": [
            "Tick0",
            "Tick1",
            "Tick2",
            "Tick3",
            "Tick4",
            "Tick5",
            "Tick6"
          ],
          "as": [
            "TickName",
            "Value"
          ]
        },
        {
          "type": "formula",
          "expr": "format(datum.Value / 100 - 1, '+.0%')",
          "as": "Label"
        }
      ]
    },
    {
      "name": "latest",
      "source": "chartData",
      "transform": [
        {
          "type": "collect",
          "sort": {
            "field": "DateKey",
            "order": "descending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "rowNumber"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.rowNumber === 1"
        }
      ]
    },
    {
      "name": "summary",
      "source": "chartData",
      "transform": [
        {
          "type": "aggregate",
          "ops": [
            "max",
            "min",
            "max",
            "min"
          ],
          "fields": [
            "DisplayIndex",
            "DisplayIndex",
            "DisplayProduct",
            "DisplayProduct"
          ],
          "as": [
            "MaxIndex",
            "MinIndex",
            "MaxProduct",
            "MinProduct"
          ]
        }
      ]
    },
    {
      "name": "hoverPoint",
      "source": "chartData",
      "transform": [
        {
          "type": "filter",
          "expr": "hoverIndex != null && datum.RowIndex === hoverIndex"
        }
      ]
    },
    {
      "name": "dateTicks",
      "source": "chartData",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.RowIndex === 1 || datum.RowIndex === length(data('chartData')) || datum.RowIndex % max(1, ceil(length(data('chartData')) / 7)) === 0"
        }
      ]
    },
    {
      "name": "periodStart",
      "source": "chartData",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.RowIndex === 1"
        }
      ]
    },
    {
      "name": "periodEnd",
      "source": "chartData",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.RowIndex === length(data('chartData'))"
        }
      ]
    }
  ],
