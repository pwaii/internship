{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "MTL product comparison dashboard with hover line and fitted 0.5-step y-axis. Adaptive y-axis labels switch from 0.5 to 1.0 spacing when crowded.",
  "background": "#F4F8FB",
  "width": 1500,
  "height": 900,
  "padding": 0,
  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": true
  },
  "data": [
    {
      "name": "dataset"
    },
    {
      "name": "chartData",
      "source": "dataset",
      "transform": [
        {
          "type": "formula",
          "expr": "toNumber(datum.Price)",
          "as": "NumericPrice"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.IndexBaseValue)",
          "as": "NumericBase"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.PR) > 1 ? toNumber(datum.PR) / 100 : toNumber(datum.PR)",
          "as": "NumericPR"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.FloorRate) > 1 ? toNumber(datum.FloorRate) / 100 : toNumber(datum.FloorRate)",
          "as": "NumericFloor"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.CapRate) > 1 ? toNumber(datum.CapRate) / 100 : toNumber(datum.CapRate)",
          "as": "NumericVolatility"
        },
        {
          "type": "formula",
          "expr": "isDate(datum.Date) ? time(datum.Date) : isNumber(datum.Date) ? (datum.Date > 1000000000 ? datum.Date : (datum.Date - 25569) * 86400000) : time(toDate(datum.Date))",
          "as": "DateKey"
        },
        {
          "type": "filter",
          "expr": "isFinite(datum.NumericPrice) && isFinite(datum.NumericBase) && datum.NumericBase > 0 && isFinite(datum.DateKey)"
        },
        {
          "type": "formula",
          "expr": "datum.NumericPrice / datum.NumericBase * 100",
          "as": "DisplayIndex"
        },
        {
          "type": "formula",
          "expr": "datum.DisplayIndex / 100 - 1",
          "as": "IndexReturnCalc"
        },
        {
          "type": "formula",
          "expr": "upper(toString(datum.FormulaType || 'PR_ONLY'))",
          "as": "FormulaKey"
        },
        {
          "type": "formula",
          "expr": "datum.FormulaKey === 'ABS_PR' ? min(max(abs(datum.IndexReturnCalc) * datum.NumericPR, datum.NumericFloor), datum.NumericVolatility) : datum.FormulaKey === 'CAP_FLOOR' ? min(max(datum.IndexReturnCalc * datum.NumericPR, datum.NumericFloor), datum.NumericVolatility) : max(datum.IndexReturnCalc * datum.NumericPR, datum.NumericFloor)",
          "as": "ProductReturnCalc"
        },
        {
          "type": "formula",
          "expr": "100 * (1 + datum.ProductReturnCalc)",
          "as": "DisplayProduct"
        },
        {
          "type": "formula",
          "expr": "toString(datum.ProductName) + ' | C' + toString(datum.CohortNo)",
          "as": "SeriesKey"
        },
        {
          "type": "collect",
          "sort": {
            "field": [
              "SeriesKey",
              "DateKey"
            ],
            "order": [
              "ascending",
              "ascending"
            ]
          }
        }
      ]
    },
    {
      "name": "productYDomain",
      "source": "chartData",
      "transform": [
        {
          "type": "aggregate",
          "ops": [
            "min",
            "max"
          ],
          "fields": [
            "DisplayProduct",
            "DisplayProduct"
          ],
          "as": [
            "MinY",
            "MaxY"
          ]
        },
        {
          "type": "formula",
          "expr": "max(1, datum.MaxY - datum.MinY)",
          "as": "Spread"
        },
        {
          "type": "formula",
          "expr": "floor((datum.MinY - max(0.5, datum.Spread * 0.12)) * 2) / 2",
          "as": "DomainMin"
        },
        {
          "type": "formula",
          "expr": "ceil((datum.MaxY + max(0.5, datum.Spread * 0.12)) * 2) / 2",
          "as": "DomainMax"
        }
      ]
    },
    {
      "name": "hundredTick",
      "source": "productYDomain",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.DomainMin <= 100 && datum.DomainMax >= 100"
        },
        {
          "type": "formula",
          "expr": "100",
          "as": "Value"
        },
        {
          "type": "formula",
          "expr": "'100'",
          "as": "Label"
        }
      ]
    },
    {
      "name": "latestByProduct",
      "source": "chartData",
      "transform": [
        {
          "type": "collect",
          "sort": {
            "field": [
              "SeriesKey",
              "DateKey"
            ],
            "order": [
              "ascending",
              "descending"
            ]
          }
        },
        {
          "type": "window",
          "groupby": [
            "SeriesKey"
          ],
          "sort": {
            "field": "DateKey",
            "order": "descending"
          },
          "ops": [
            "row_number"
          ],
          "as": [
            "LatestRank"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.LatestRank === 1"
        },
        {
          "type": "collect",
          "sort": {
            "field": "SeriesKey",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "CardNo"
          ]
        }
      ]
    },
    {
      "name": "visibleCards",
      "source": "latestByProduct",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.CardNo <= 12"
        }
      ]
    },
    {
      "name": "yTickData",
      "source": "productYDomain",
      "transform": [
        {
          "type": "formula",
          "expr": "datum.DomainMax - datum.DomainMin",
          "as": "AxisSpan"
        },
        {
          "type": "formula",
          "expr": "floor(datum.AxisSpan / 0.5) + 1",
          "as": "HalfStepCount"
        },
        {
          "type": "formula",
          "expr": "datum.HalfStepCount > 15 ? 1 : 0.5",
          "as": "TickStep"
        },
        {
          "type": "formula",
          "expr": "ceil(datum.DomainMin / datum.TickStep) * datum.TickStep",
          "as": "FirstTick"
        },
        {
          "type": "formula",
          "expr": "sequence(datum.FirstTick, datum.DomainMax + datum.TickStep * 0.5, datum.TickStep)",
          "as": "TickArray"
        },
        {
          "type": "flatten",
          "fields": [
            "TickArray"
          ],
          "as": [
            "Value"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.Value >= datum.DomainMin && datum.Value <= datum.DomainMax"
        },
        {
          "type": "formula",
          "expr": "datum.TickStep >= 1 ? format(datum.Value, '.0f') : format(datum.Value, '.1f')",
          "as": "Label"
        }
      ]
    },
    {
      "name": "dateTicks",
      "source": "chartData",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.DateKey === data('chartData')[0].DateKey || datum.DateKey === data('chartData')[length(data('chartData')) - 1].DateKey || datum.DateKey % max(1, ceil((data('chartData')[length(data('chartData')) - 1].DateKey - data('chartData')[0].DateKey) / 7)) < 86400000"
        }
      ]
    },
    {
      "name": "hoverRows",
      "source": "chartData",
      "transform": [
        {
          "type": "formula",
          "expr": "hoverDateKey == null ? null : abs(datum.DateKey - hoverDateKey)",
          "as": "HoverDistance"
        },
        {
          "type": "window",
          "groupby": [
            "SeriesKey"
          ],
          "sort": {
            "field": "HoverDistance",
            "order": "ascending"
          },
          "ops": [
            "row_number"
          ],
          "as": [
            "HoverRank"
          ]
        },
        {
          "type": "filter",
          "expr": "hoverDateKey != null && datum.HoverRank === 1"
        },
        {
          "type": "collect",
          "sort": {
            "field": "SeriesKey",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "HoverRowNo"
          ]
        }
      ]
    },
    {
      "name": "hoverDate",
      "source": "hoverRows",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.HoverRowNo === 1"
        }
      ]
    }
  ],
