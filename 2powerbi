    },
    {
      "name": "chartData",
      "source": "dataset",
      "transform": [
        {
          "type": "formula",
          "expr": "toNumber(datum.Price)",
          "as": "NumericPrice"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.IndexBaseValue)",
          "as": "NumericBase"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.PR) > 1 ? toNumber(datum.PR) / 100 : toNumber(datum.PR)",
          "as": "NumericPR"
        },
        {
          "type": "formula",
          "expr": "isFinite(toNumber(datum.FloorRate)) ? (toNumber(datum.FloorRate) > 1 ? toNumber(datum.FloorRate) / 100 : toNumber(datum.FloorRate)) : 0",
          "as": "NumericFloor"
        },
        {
          "type": "formula",
          "expr": "isFinite(toNumber(datum.Volatility)) ? (toNumber(datum.Volatility) > 1 ? toNumber(datum.Volatility) / 100 : toNumber(datum.Volatility)) : (isFinite(toNumber(datum.CapRate)) ? (toNumber(datum.CapRate) > 1 ? toNumber(datum.CapRate) / 100 : toNumber(datum.CapRate)) : 1)",
          "as": "NumericVolatility"
        },
        {
          "type": "formula",
          "expr": "isDate(datum.Date) ? time(datum.Date) : isNumber(datum.Date) ? (datum.Date > 100000000000 ? datum.Date : datum.Date > 1000000000 ? datum.Date * 1000 : (datum.Date - 25569) * 86400000) : isFinite(toNumber(datum.Date)) ? (toNumber(datum.Date) > 100000000000 ? toNumber(datum.Date) : toNumber(datum.Date) > 1000000000 ? toNumber(datum.Date) * 1000 : (toNumber(datum.Date) - 25569) * 86400000) : time(toDate(datum.Date))",
          "as": "DateKey"
        },
        {
          "type": "formula",
          "expr": "isDate(datum.CohortStartDate) ? time(datum.CohortStartDate) : isNumber(datum.CohortStartDate) ? (datum.CohortStartDate > 1000000000 ? datum.CohortStartDate : (datum.CohortStartDate - 25569) * 86400000) : isFinite(toNumber(datum.CohortStartDate)) ? (toNumber(datum.CohortStartDate) > 1000000000 ? toNumber(datum.CohortStartDate) : (toNumber(datum.CohortStartDate) - 25569) * 86400000) : time(toDate(datum.CohortStartDate))",
          "as": "CohortStartKey"
        },
        {
          "type": "filter",
          "expr": "isFinite(datum.NumericPrice) && isFinite(datum.NumericBase) && datum.NumericBase > 0 && isFinite(datum.DateKey)"
        },
        {
          "type": "formula",
          "expr": "datum.NumericPrice / datum.NumericBase * 100",
          "as": "DisplayIndex"
        },
        {
          "type": "formula",
          "expr": "datum.DisplayIndex / 100 - 1",
          "as": "IndexReturnCalc"
        },
        {
          "type": "formula",
          "expr": "upper(toString(datum.Formula || datum.FormulaType || 'PR_ONLY'))",
          "as": "FormulaKey"
        },
        {
          "type": "formula",
          "expr": "isFinite(toNumber(datum.ProductReturn)) ? toNumber(datum.ProductReturn) : isFinite(toNumber(datum.ProductReturnFromFormula)) ? toNumber(datum.ProductReturnFromFormula) : datum.FormulaKey === 'ABS_PR' ? min(max(abs(datum.IndexReturnCalc) * datum.NumericPR, isFinite(datum.NumericFloor) ? datum.NumericFloor : 0), isFinite(datum.NumericVolatility) ? datum.NumericVolatility : 1) : datum.FormulaKey === 'CAP_FLOOR' ? min(max(datum.IndexReturnCalc * datum.NumericPR, isFinite(datum.NumericFloor) ? datum.NumericFloor : 0), isFinite(datum.NumericVolatility) ? datum.NumericVolatility : 1) : max(datum.IndexReturnCalc * datum.NumericPR, isFinite(datum.NumericFloor) ? datum.NumericFloor : 0)",
          "as": "ProductReturnCalc"
        },
        {
          "type": "formula",
          "expr": "isFinite(toNumber(datum.ProductValue)) ? toNumber(datum.ProductValue) : isFinite(datum.ProductReturnCalc) ? 100 * (1 + datum.ProductReturnCalc) : null",
          "as": "DisplayProduct"
        },
        {
          "type": "filter",
          "expr": "isFinite(datum.DisplayProduct)"
        },
        {
          "type": "formula",
          "expr": "toString(datum.ProductName) + ' | C' + toString(datum.CohortNo)",
          "as": "SeriesKey"
        },
        {
          "type": "collect",
          "sort": {
            "field": [
              "SeriesKey",
              "DateKey"
            ],
            "order": [
              "ascending",
              "ascending"
            ]
          }
        },
        {
          "type": "window",
          "groupby": [
            "SeriesKey"
          ],
          "sort": {
            "field": "DateKey",
            "order": "ascending"
          },
          "ops": [
            "row_number"
          ],
          "fields": [
            null
          ],
          "as": [
            "RowIndex"
          ]
        },
        {
          "type": "formula",
          "expr": "datum.DisplayProduct",
          "as": "DisplayProductNormalized"
        }
      ]
    },
    {
      "name": "productYDomain",
      "source": "chartData",
      "transform": [
        {
          "type": "aggregate",
          "ops": [
            "min",
            "max"
          ],
          "fields": [
            "DisplayProductNormalized",
            "DisplayProductNormalized"
          ],
          "as": [
            "MinY",
            "MaxY"
          ]
        },
        {
          "type": "formula",
          "expr": "max(1, datum.MaxY - datum.MinY)",
          "as": "Spread"
        },
        {
          "type": "formula",
          "expr": "floor((datum.MinY - max(0.5, datum.Spread * 0.12)) * 2) / 2",
          "as": "DomainMin"
        },
        {
          "type": "formula",
          "expr": "ceil((datum.MaxY + max(0.5, datum.Spread * 0.12)) * 2) / 2",
          "as": "DomainMax"
        }
      ]
    },
    {
      "name": "rowIndexRange",
      "source": "chartData",
      "transform": [
        {
          "type": "aggregate",
          "ops": [
            "max"
          ],
          "fields": [
            "RowIndex"
          ],
          "as": [
            "MaxRowIndex"
          ]
        }
      ]
    },
    {
      "name": "hundredTick",
      "source": "productYDomain",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.DomainMin <= 100 && datum.DomainMax >= 100"
        },
        {
          "type": "formula",
          "expr": "100",
          "as": "Value"
        },
        {
          "type": "formula",
          "expr": "'100'",
          "as": "Label"
        }
      ]
    },
    {
      "name": "latestByProduct",
      "source": "chartData",
      "transform": [
        {
          "type": "collect",
          "sort": {
            "field": [
              "SeriesKey",
              "DateKey"
            ],
            "order": [
              "ascending",
              "descending"
            ]
          }
        },
        {
          "type": "window",
          "groupby": [
            "SeriesKey"
          ],
          "sort": {
            "field": "DateKey",
            "order": "descending"
          },
          "ops": [
            "row_number"
          ],
          "as": [
            "LatestRank"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.LatestRank === 1"
        },
        {
          "type": "collect",
          "sort": {
            "field": "SeriesKey",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "CardNo"
          ]
        }
      ]
    },
    {
      "name": "visibleCards",
      "source": "latestByProduct",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.CardNo <= 12"
        }
      ]
    },
    {
      "name": "hiddenCards",
      "source": "latestByProduct",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.CardNo > 12"
        },
        {
          "type": "aggregate",
          "ops": [
            "count"
          ],
          "as": [
            "HiddenCount"
          ]
        }
      ]
    },
    {
      "name": "yTickData",
      "source": "productYDomain",
      "transform": [
        {
          "type": "formula",
          "expr": "datum.DomainMax - datum.DomainMin",
          "as": "AxisSpan"
        },
        {
          "type": "formula",
          "expr": "floor(datum.AxisSpan / 0.5) + 1",
          "as": "HalfStepCount"
        },
        {
          "type": "formula",
          "expr": "datum.HalfStepCount > 15 ? 1 : 0.5",
          "as": "TickStep"
        },
        {
          "type": "formula",
          "expr": "ceil(datum.DomainMin / datum.TickStep) * datum.TickStep",
          "as": "FirstTick"
        },
        {
          "type": "formula",
          "expr": "sequence(datum.FirstTick, datum.DomainMax + datum.TickStep * 0.5, datum.TickStep)",
          "as": "TickArray"
        },
        {
          "type": "flatten",
          "fields": [
            "TickArray"
          ],
          "as": [
            "Value"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.Value >= datum.DomainMin && datum.Value <= datum.DomainMax"
        },
        {
          "type": "formula",
          "expr": "abs(datum.Value - 100) < 0.0001 ? '0%' : datum.TickStep >= 1 ? format((datum.Value - 100) / 100, '+.0%') : format((datum.Value - 100) / 100, '+.1%')",
          "as": "Label"
        }
      ]
    },
    {
      "name": "dateTickSource",
      "source": "chartData",
      "transform": [
        {
          "type": "filter",
          "expr": "length(data('latestByProduct')) > 0 && datum.SeriesKey === data('latestByProduct')[0].SeriesKey"
        },
        {
          "type": "collect",
          "sort": {
            "field": "DateKey",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "TickRowNo"
          ]
        }
      ]
    },
    {
      "name": "dateTicks",
      "source": "dateTickSource",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.TickRowNo === 1 || datum.TickRowNo === length(data('dateTickSource')) || (datum.TickRowNo - 1) % max(1, ceil(length(data('dateTickSource')) / 4)) === 0"
        }
      ]
    },
    {
      "name": "hoverAnchor",
      "source": "chartData",
      "transform": [
        {
          "type": "formula",
          "expr": "hoverIndex == null ? null : abs(datum.DateKey - hoverIndex)",
          "as": "HoverDistance"
        },
        {
          "type": "collect",
          "sort": {
            "field": "HoverDistance",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "HoverRank"
          ]
        },
        {
          "type": "filter",
          "expr": "hoverIndex != null && datum.HoverRank === 1"
        }
      ]
    },
    {
      "name": "hoverRows",
      "source": "hoverAnchor",
      "transform": [
        {
          "type": "collect",
          "sort": {
            "field": "SeriesKey",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "HoverRowNo"
          ]
        }
      ]
    },
    {
      "name": "hoverRowsVisible",
      "source": "hoverRows",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.HoverRowNo <= 10"
        }
      ]
    },
    {
      "name": "hoverRowsHidden",
      "source": "hoverRows",
