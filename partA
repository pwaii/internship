/**
 * Central Pivot Builder controller.
 *
 * Run this script in PivotBuilder_Central.xlsx. It returns one JSON string for
 * Power Automate. The flow uses inputWorkbookPath to select the input file, then
 * passes the same JSON string to PivotBuilder_Cloud.ts in that input workbook.
 */

const BUILDER_SETUP_SHEET = "PivotBuilder_Setup";
const BUILDER_FIRST_ROW = 9;
const BUILDER_LAST_ROW = 200;
const BUILDER_TEMPLATE_VERSION = "PB_CENTRAL_1";

type BuilderCell = string | number | boolean;

interface BuilderPivotRow {
  template: string;
  pivotName: string;
  outputSheet: string;
  rows: string;
  rowNames: string;
  groupRules: string;
  displayValues: string;
  values: string;
  filters: string;
  conditions: string;
  nextRight: boolean;
  sourceRow: number;
}

interface BuilderPayload {
  version: string;
  action: string;
  inputWorkbookPath: string;
  dataSheet: string;
  selectedTemplate: string;
  rows: BuilderPivotRow[];
}

const CENTRAL_EMBEDDED_ROWS: BuilderCell[][] = [
  [
    "Default", "Sample Pivot", "Pivot_Output", "Save to input cloud file",
    "category", "", "", "status", "id,amount", "status", "status=Open",
    "", "No", "Edit this embedded template for your real column names."
  ]
];

function main(workbook: ExcelScript.Workbook): string {
  let setup = workbook.getWorksheet(BUILDER_SETUP_SHEET);
  if (!setup) {
    setup = createCentralSetup(workbook);
    setBuilderStatus(setup, "Central builder created. Enter the input workbook path and configure templates.");
    return "";
  }

  ensureCentralTemplates(setup);
  applyCentralStyle(setup);
  refreshCentralTemplateChoices(setup);
  applyCentralValidations(setup);

  const rawInputWorkbookPath = builderText(setup.getRange("B3").getValue());
  const inputWorkbookPath = normalizeSharePointFilePath(rawInputWorkbookPath);
  if (inputWorkbookPath !== rawInputWorkbookPath) setup.getRange("B3").setValue(inputWorkbookPath);
  const dataSheet = builderText(setup.getRange("B4").getValue());
  const selectedTemplate = builderText(setup.getRange("B5").getValue()) || "All";
  const action = builderText(setup.getRange("B2").getValue()) || "Refresh fields only";
  if (!inputWorkbookPath) throwBuilder(setup, "Input workbook path is required in B3.");
  if (/^[A-Za-z]:[\\/]/.test(inputWorkbookPath)) {
    throwBuilder(setup, "B3 cannot use a local C:\\ path. Upload the input workbook to OneDrive/SharePoint and enter its cloud path.");
  }
  if (/^https?:\/\//i.test(inputWorkbookPath) || /^\/:/i.test(inputWorkbookPath)) {
    throwBuilder(setup, "B3 contains a sharing link that cannot be resolved. Use a SharePoint library path such as /Shared Documents/Inputs/File.xlsx.");
  }
  if (!dataSheet) throwBuilder(setup, "Input data sheet is required in B4.");

  const rows = readCentralRows(setup).filter((row: BuilderPivotRow) =>
    centralTemplateSelected(row.template, selectedTemplate)
  );
  if (rows.length === 0 && centralEquals(action, "Build pivots")) {
    throwBuilder(setup, `No setup rows match template selection: ${selectedTemplate}`);
  }

  const payload: BuilderPayload = {
    version: BUILDER_TEMPLATE_VERSION,
    action,
    inputWorkbookPath,
    dataSheet,
    selectedTemplate,
    rows
  };
  const result = JSON.stringify(payload);
  setBuilderStatus(setup, `Ready for Power Automate: ${action}; ${rows.length} PivotTable configuration row(s).`);
  return result;
}

function createCentralSetup(workbook: ExcelScript.Workbook): ExcelScript.Worksheet {
  const sheet = workbook.addWorksheet(BUILDER_SETUP_SHEET);
  sheet.setShowGridlines(false);

  sheet.getRange("A1:N1").merge(false);
  sheet.getRange("A1").setValue("Excel Pivot Builder - Central Cloud Controller");
  sheet.getRange("A3").setValue("Input workbook path");
  sheet.getRange("A4").setValue("Input data sheet");
  sheet.getRange("A5").setValue("Selected template");
  sheet.getRange("A6").setValue("Status");
  sheet.getRange("A2").setValue("Flow action");
  sheet.getRange("B2").setValue("Refresh fields only");
  sheet.getRange("B3:D3").merge(false);
  sheet.getRange("B3").setValue("/Shared Documents/Inputs/Input.xlsx");
  sheet.getRange("B4").setValue("Data");
  sheet.getRange("B5").setValue("All");
  sheet.getRange("B6:N6").merge(false);

  sheet.getRange("A8:N8").setValues([[
    "Template", "Pivot Name", "Output Sheet", "Save Behavior", "Rows", "Row Names",
    "Group Rules", "Display Values", "Values To Count/Sum", "Filters", "Conditions",
    "Reserved", "Next Pivot Right", "Notes"
  ]]);
  sheet.getRange("P1:S1").merge(false);
  sheet.getRange("P1").setValue("Builder Suggestions");
  sheet.getRange("P3").setValue("Field Suggestions");
  sheet.getRange("S3").setValue("Template Choices");

  seedCentralTemplates(sheet);
  sheet.getRange("Z1").setValue(BUILDER_TEMPLATE_VERSION);
  applyCentralStyle(sheet);
  refreshCentralTemplateChoices(sheet);
  applyCentralValidations(sheet);
  return sheet;
}

function applyCentralStyle(sheet: ExcelScript.Worksheet) {
  const burgundy = "#8D021F";
  const black = "#000000";
  const white = "#FFFFFF";
  const gray = "#F2F4F7";
  const border = "#C8CDD4";

  sheet.getRange("A1:S500").getFormat().getFont().setName("Aptos");
  sheet.getRange("A1:S500").getFormat().getFont().setSize(10);
  sheet.getRange("A1:S500").getFormat().getFill().setColor(gray);
  sheet.getRange("A1:N1").getFormat().getFill().setColor(burgundy);
  sheet.getRange("A1:N1").getFormat().getFont().setColor(white);
  sheet.getRange("A1:N1").getFormat().getFont().setBold(true);
  sheet.getRange("A1:N1").getFormat().getFont().setSize(16);
  sheet.getRange("A3:N6").getFormat().getFill().setColor(white);
  sheet.getRange("A3:A6").getFormat().getFont().setBold(true);
  sheet.getRange("A2:N2").getFormat().getFill().setColor(white);
  sheet.getRange("A2").getFormat().getFont().setBold(true);

  sheet.getRange("A8:N8").getFormat().getFill().setColor(black);
  sheet.getRange("A8:N8").getFormat().getFont().setColor(white);
  sheet.getRange("A8:N8").getFormat().getFont().setBold(true);
  sheet.getRange("A8:N8").getFormat().setWrapText(true);
  sheet.getRange(`A9:N${BUILDER_LAST_ROW}`).getFormat().getFill().setColor(white);
  sheet.getRange(`A9:N${BUILDER_LAST_ROW}`).getFormat().setWrapText(true);
  sheet.getRange(`A9:N${BUILDER_LAST_ROW}`).getFormat().setRowHeight(48);
  applyCleanBorders(sheet.getRange(`A8:N${BUILDER_LAST_ROW}`), border);

  sheet.getRange("P1:S1").getFormat().getFill().setColor(burgundy);
  sheet.getRange("P1:S1").getFormat().getFont().setColor(white);
  sheet.getRange("P1:S1").getFormat().getFont().setBold(true);
  sheet.getRange("P3:S3").getFormat().getFill().setColor(black);
  sheet.getRange("P3:S3").getFormat().getFont().setColor(white);
  sheet.getRange("P3:S3").getFormat().getFont().setBold(true);
  sheet.getRange("P4:S500").getFormat().getFill().setColor(white);

  const widths: { [key: string]: number } = {
    A: 120, B: 150, C: 125, D: 140, E: 160, F: 145, G: 250,
    H: 130, I: 145, J: 150, K: 190, L: 80, M: 115, N: 220,
    O: 25, P: 150, Q: 25, R: 25, S: 150
  };
  Object.keys(widths).forEach((column: string) => {
    sheet.getRange(`${column}:${column}`).getFormat().setColumnWidth(widths[column]);
  });
  sheet.getFreezePanes().freezeRows(8);
}

function applyCentralValidations(setup: ExcelScript.Worksheet) {
  centralListValidation(setup.getRange("B2"), "Refresh fields only,Build pivots", true);
  centralListValidation(setup.getRange("B5"), "=$S$4:$S$500", true);
  centralListValidation(setup.getRange(`A${BUILDER_FIRST_ROW}:A${BUILDER_LAST_ROW}`), "=$S$5:$S$500", false);
  centralListValidation(setup.getRange(`D${BUILDER_FIRST_ROW}:D${BUILDER_LAST_ROW}`), "Save to input cloud file", true);
  centralListValidation(setup.getRange(`M${BUILDER_FIRST_ROW}:M${BUILDER_LAST_ROW}`), "No,Yes", true);
  ["E", "H", "I", "J", "K"].forEach((column: string) => {
    centralListValidation(setup.getRange(`${column}${BUILDER_FIRST_ROW}:${column}${BUILDER_LAST_ROW}`), "=$P$4:$P$500", false);
  });
}

function centralListValidation(range: ExcelScript.Range, source: string, showError: boolean) {
  const validation = range.getDataValidation();
  validation.clear();
  validation.setRule({ list: { inCellDropDown: true, source } });
  validation.setIgnoreBlanks(true);
  validation.setErrorAlert({
    showAlert: showError,
    title: "Central Pivot Builder",
    message: "Choose a suggestion or type the required comma/semicolon expression."
  });
}

function readCentralRows(setup: ExcelScript.Worksheet): BuilderPivotRow[] {
  const values = setup.getRange(`A${BUILDER_FIRST_ROW}:N${BUILDER_LAST_ROW}`).getValues();
  const result: BuilderPivotRow[] = [];
  values.forEach((row: (string | number | boolean)[], index: number) => {
    const template = builderText(row[0]);
    const pivotName = builderText(row[1]);
    if (!template || !pivotName) return;
    result.push({
      template,
      pivotName,
      outputSheet: builderText(row[2]) || "Pivot_Output",
      rows: builderText(row[4]),
      rowNames: builderText(row[5]),
      groupRules: builderText(row[6]),
      displayValues: builderText(row[7]),
      values: builderText(row[8]),
      filters: builderText(row[9]),
      conditions: builderText(row[10]),
      nextRight: centralYes(builderText(row[12])),
      sourceRow: BUILDER_FIRST_ROW + index
    });
  });
  return result;
}

function ensureCentralTemplates(setup: ExcelScript.Worksheet) {
  if (builderText(setup.getRange("Z1").getValue()) === BUILDER_TEMPLATE_VERSION) return;
  seedCentralTemplates(setup);
  setup.getRange("Z1").setValue(BUILDER_TEMPLATE_VERSION);
}

function seedCentralTemplates(setup: ExcelScript.Worksheet) {
  const target = setup.getRange(`A${BUILDER_FIRST_ROW}:N${BUILDER_LAST_ROW}`);
  const values = target.getValues() as BuilderCell[][];
  const embeddedNames = centralDistinct(CENTRAL_EMBEDDED_ROWS.map((row: BuilderCell[]) => builderText(row[0])));

  embeddedNames.forEach((templateName: string) => {
    const exists = values.some((row: BuilderCell[]) => centralEquals(builderText(row[0]), templateName));
    if (exists) return;
    CENTRAL_EMBEDDED_ROWS
      .filter((row: BuilderCell[]) => centralEquals(builderText(row[0]), templateName))
      .forEach((templateRow: BuilderCell[]) => {
        const blankIndex = values.findIndex((row: BuilderCell[]) => builderText(row[0]) === "" && builderText(row[1]) === "");
        if (blankIndex < 0) throw new Error("No blank setup rows remain for embedded templates.");
        values[blankIndex] = templateRow.slice(0, 14);
      });
  });
  target.setValues(values);
}

function refreshCentralTemplateChoices(setup: ExcelScript.Worksheet) {
  const values = setup.getRange(`A${BUILDER_FIRST_ROW}:A${BUILDER_LAST_ROW}`).getValues();
  const templates: string[] = ["All"];
  values.forEach((row: (string | number | boolean)[]) => {
    const name = builderText(row[0]);
    if (name && !templates.some((existing: string) => centralEquals(existing, name))) templates.push(name);
  });
  setup.getRange("S4:S500").clear(ExcelScript.ClearApplyTo.contents);
  setup.getRangeByIndexes(3, 18, templates.length, 1).setValues(templates.map((name: string) => [name]));
}

function centralTemplateSelected(template: string, selected: string): boolean {
  if (centralEquals(selected, "All") || centralEquals(selected, "All Templates")) return true;
  return centralSplitList(selected).some((item: string) => centralEquals(item, template));
}

function centralSplitList(value: string): string[] {
  return value
    .replace(/\r?\n/g, ",")
    .split(",")
    .map((item: string) => item.trim())
    .filter((item: string) => item.length > 0);
}

function centralDistinct(values: string[]): string[] {
  const result: string[] = [];
  values.forEach((value: string) => {
    if (!result.some((existing: string) => centralEquals(existing, value))) result.push(value);
  });
  return result;
}

function builderText(value: unknown): string {
  if (value === null || value === undefined) return "";
  return String(value).trim();
}

function centralEquals(left: string, right: string): boolean {
  return left.trim().toLowerCase() === right.trim().toLowerCase();
}

function centralYes(value: string): boolean {
  return ["yes", "y", "true", "1", "checked"].includes(value.trim().toLowerCase());
}

function normalizeSharePointFilePath(value: string): string {
  const clean = value.trim();
  if (!/^https?:\/\//i.test(clean)) return clean;

  // Remove query/hash and the SharePoint host. Direct links and ':x:/r' links
  // retain the real library path; opaque ':x:/s' or ':x:/g' links do not.
  const withoutQuery = clean.split("?")[0].split("#")[0];
  let path = withoutQuery.replace(/^https?:\/\/[^/]+/i, "");
  path = path.replace(/^\/:x:\/r/i, "");
  path = path.replace(/^\/sites\/[^/]+/i, "");
  path = path.replace(/^\/teams\/[^/]+/i, "");
  if (/^\/:/i.test(path)) return clean;

  try {
    return decodeURIComponent(path);
  } catch (_error) {
    return path;
  }
}

function setBuilderStatus(setup: ExcelScript.Worksheet, message: string) {
  setup.getRange("B6").setValue(message);
}

function throwBuilder(setup: ExcelScript.Worksheet, message: string): never {
  setBuilderStatus(setup, `ERROR: ${message}`);
  throw new Error(message);
}

function applyCleanBorders(range: ExcelScript.Range, color: string) {
  const format = range.getFormat();
  [ExcelScript.BorderIndex.diagonalDown, ExcelScript.BorderIndex.diagonalUp].forEach((index: ExcelScript.BorderIndex) => {
    format.getRangeBorder(index).setStyle(ExcelScript.BorderLineStyle.none);
  });
  [
    ExcelScript.BorderIndex.edgeTop,
    ExcelScript.BorderIndex.edgeBottom,
    ExcelScript.BorderIndex.edgeLeft,
    ExcelScript.BorderIndex.edgeRight,
    ExcelScript.BorderIndex.insideHorizontal,
    ExcelScript.BorderIndex.insideVertical
  ].forEach((index: ExcelScript.BorderIndex) => {
    const border = format.getRangeBorder(index);
    border.setColor(color);
    border.setStyle(ExcelScript.BorderLineStyle.continuous);
    border.setWeight(ExcelScript.BorderWeight.thin);
  });
}
