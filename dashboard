============================================================
VISUAL 2 - CLAUDE-STYLE INDEX TREND CARDS
============================================================

Add these fields to the Deneb visual dataset:
- IndexPrices[Date]
- IndexPrices[IndexName]
- IndexPrices[Price]

Paste this JSON into Deneb:

{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#F7F8FA",
  "data": {
    "name": "dataset"
  },
  "transform": [
    {
      "window": [
        {
          "op": "first_value",
          "field": "Price",
          "as": "StartPrice"
        },
        {
          "op": "last_value",
          "field": "Price",
          "as": "LatestPrice"
        }
      ],
      "sort": [
        {
          "field": "Date",
          "order": "ascending"
        }
      ],
      "groupby": ["IndexName"]
    },
    {
      "calculate": "(datum.LatestPrice - datum.StartPrice) / datum.StartPrice",
      "as": "IndexReturn"
    }
  ],
  "facet": {
    "field": "IndexName",
    "type": "nominal",
    "columns": 2,
    "title": null,
    "header": {
      "labelFont": "Segoe UI",
      "labelFontSize": 13,
      "labelFontWeight": "bold",
      "labelColor": "#1F2933"
    }
  },
  "spec": {
    "width": 280,
    "height": 130,
    "layer": [
      {
        "mark": {
          "type": "rect",
          "fill": "#FFFFFF",
          "stroke": "#E5E7EB",
          "cornerRadius": 8
        }
      },
      {
        "mark": {
          "type": "area",
          "interpolate": "monotone",
          "line": {
            "color": "#C8102E",
            "strokeWidth": 2
          },
          "color": {
            "x1": 1,
            "y1": 1,
            "x2": 1,
            "y2": 0,
            "gradient": "linear",
            "stops": [
              {
                "offset": 0,
                "color": "#FFFFFF"
              },
              {
                "offset": 1,
                "color": "#F8B4BE"
              }
            ]
          },
          "opacity": 0.9
        },
        "encoding": {
          "x": {
            "field": "Date",
            "type": "temporal",
            "axis": {
              "title": null,
              "labelFontSize": 9,
              "grid": false
            }
          },
          "y": {
            "field": "Price",
            "type": "quantitative",
            "axis": {
              "title": null,
              "labelFontSize": 9,
              "gridColor": "#EEF2F7"
            },
            "scale": {
              "zero": false
            }
          },
          "tooltip": [
            {
              "field": "Date",
              "type": "temporal"
            },
            {
              "field": "IndexName",
              "type": "nominal"
            },
            {
              "field": "Price",
              "type": "quantitative",
              "format": ",.2f"
            },
            {
              "field": "IndexReturn",
              "type": "quantitative",
              "format": ".1%"
            }
          ]
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "y": "independent"
    }
  },
  "config": {
    "font": "Segoe UI",
    "view": {
      "stroke": "transparent"
    }
  }
}

