{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "MTL index comparison dashboard with assigned theme, aligned y-axis, 0.5-step labels, and forced 100.0 tick. Adaptive y-axis labels switch from 0.5 to 1.0 spacing when crowded.",
  "background": "#F4F8FB",
  "width": 1500,
  "height": 900,
  "padding": 0,
  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": true
  },
  "signals": [
    {
      "name": "chartRemarkY",
      "update": "plotBottom + 58"
    },
    {
      "name": "dateTitleY",
      "update": "plotBottom + 38"
    },
    {
      "name": "dateTickY",
      "update": "plotBottom + 22"
    },
    {
      "name": "plotMidY",
      "update": "(plotTop + plotBottom) / 2"
    },
    {
      "name": "plotBottom",
      "update": "790"
    },
    {
      "name": "plotTop",
      "update": "chartPanelY + 90"
    },
    {
      "name": "chartTitleY",
      "update": "chartPanelY + 30"
    },
    {
      "name": "chartPanelY",
      "update": "220 + cardRows * 84 + 24"
    },
    {
      "name": "cardRows",
      "update": "max(1, ceil(length(data('visibleCards')) / 4))"
    },
    {
      "name": "hoverX",
      "value": null,
      "on": [
        {
          "events": {
            "type": "mousemove",
            "markname": "hoverArea"
          },
          "update": "clamp(x(), 150, 1360)"
        },
        {
          "events": {
            "type": "mouseout",
            "markname": "hoverArea"
          },
          "update": "null"
        }
      ]
    },
    {
      "name": "hoverDateKey",
      "update": "hoverX == null || length(data('indexSeries')) == 0 ? null : invert('x', hoverX)"
    }
  ],
  "data": [
    {
      "name": "dataset"
    },
    {
      "name": "rawIndexRows",
      "source": "dataset",
      "transform": [
        {
          "type": "formula",
          "expr": "toNumber(datum.Price)",
          "as": "NumericPrice"
        },
        {
          "type": "formula",
          "expr": "isDate(datum.Date) ? time(datum.Date) : isNumber(datum.Date) ? (datum.Date > 1000000000 ? datum.Date : (datum.Date - 25569) * 86400000) : time(toDate(datum.Date))",
          "as": "DateKey"
        },
        {
          "type": "filter",
          "expr": "isFinite(datum.NumericPrice) && isFinite(datum.DateKey) && datum.IndexCode != null"
        },
        {
          "type": "formula",
          "expr": "toString(datum.IndexCode)",
          "as": "SeriesKey"
        },
        {
          "type": "formula",
          "expr": "datum.IndexName ? toString(datum.IndexName) : toString(datum.IndexCode)",
          "as": "SeriesName"
        }
      ]
    },
    {
      "name": "indexDaily",
      "source": "rawIndexRows",
      "transform": [
        {
          "type": "aggregate",
          "groupby": [
            "SeriesKey",
            "SeriesName",
            "DateKey"
          ],
          "ops": [
            "mean"
          ],
          "fields": [
            "NumericPrice"
          ],
          "as": [
            "IndexPrice"
          ]
        },
        {
          "type": "collect",
          "sort": {
            "field": [
              "SeriesKey",
              "DateKey"
            ],
            "order": [
              "ascending",
              "ascending"
            ]
          }
        }
      ]
    },
    {
      "name": "indexSeries",
      "source": "indexDaily",
      "transform": [
        {
          "type": "window",
          "groupby": [
            "SeriesKey"
          ],
          "sort": {
            "field": "DateKey",
            "order": "ascending"
          },
          "ops": [
            "row_number",
            "first_value"
          ],
          "fields": [
            null,
            "IndexPrice"
          ],
          "as": [
            "RowIndex",
            "StartPrice"
          ]
        },
        {
          "type": "formula",
          "expr": "datum.StartPrice > 0 ? datum.IndexPrice / datum.StartPrice * 100 : datum.IndexPrice",
          "as": "CompareIndex"
        },
        {
          "type": "formula",
          "expr": "datum.CompareIndex / 100 - 1",
          "as": "IndexGrowth"
        }
      ]
    },
    {
      "name": "latestByIndex",
      "source": "indexSeries",
      "transform": [
        {
          "type": "window",
          "groupby": [
            "SeriesKey"
          ],
          "sort": {
            "field": "DateKey",
            "order": "descending"
          },
          "ops": [
            "row_number"
          ],
          "as": [
            "LatestRank"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.LatestRank === 1"
        },
        {
          "type": "collect",
          "sort": {
            "field": "SeriesKey",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "CardNo"
          ]
        }
      ]
    },
    {
      "name": "visibleCards",
      "source": "latestByIndex",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.CardNo <= 12"
        }
      ]
    },
    {
      "name": "yDomain",
      "source": "indexSeries",
      "transform": [
        {
          "type": "aggregate",
          "ops": [
            "min",
            "max"
          ],
          "fields": [
            "CompareIndex",
            "CompareIndex"
          ],
          "as": [
            "MinY",
            "MaxY"
          ]
        },
        {
          "type": "formula",
          "expr": "max(1, datum.MaxY - datum.MinY)",
          "as": "Spread"
        },
        {
          "type": "formula",
          "expr": "floor((datum.MinY - datum.Spread * 0.12) * 2) / 2",
          "as": "DomainMin"
        },
        {
          "type": "formula",
          "expr": "ceil((datum.MaxY + datum.Spread * 0.12) * 2) / 2",
          "as": "DomainMax"
        }
      ]
    },
    {
      "name": "dateTicksSource",
      "source": "indexSeries",
      "transform": [
        {
          "type": "filter",
          "expr": "length(data('latestByIndex')) > 0 && datum.SeriesKey === data('latestByIndex')[0].SeriesKey"
        }
      ]
    },
    {
      "name": "dateTicks",
      "source": "dateTicksSource",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.RowIndex === 1 || datum.RowIndex === length(data('dateTicksSource')) || datum.RowIndex % max(1, ceil(length(data('dateTicksSource')) / 7)) === 0"
        }
      ]
    },
    {
      "name": "hoverRows",
      "source": "indexSeries",
      "transform": [
        {
          "type": "formula",
          "expr": "hoverDateKey == null ? null : abs(datum.DateKey - hoverDateKey)",
          "as": "HoverDistance"
        },
        {
          "type": "window",
          "groupby": [
            "SeriesKey"
          ],
          "sort": {
            "field": "HoverDistance",
            "order": "ascending"
          },
          "ops": [
            "row_number"
          ],
          "as": [
            "HoverRank"
          ]
        },
        {
          "type": "filter",
          "expr": "hoverDateKey != null && datum.HoverRank === 1"
        },
        {
          "type": "collect",
          "sort": {
            "field": "SeriesKey",
            "order": "ascending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "HoverRowNo"
          ]
        }
      ]
    },
    {
      "name": "hoverDate",
      "source": "hoverRows",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.HoverRowNo === 1"
        }
      ]
    },
    {
      "name": "manualYTicks",
      "source": "yDomain",
      "transform": [
        {
          "type": "formula",
          "expr": "datum.DomainMax - datum.DomainMin",
          "as": "AxisSpan"
        },
        {
          "type": "formula",
          "expr": "floor(datum.AxisSpan / 0.5) + 1",
          "as": "HalfStepCount"
        },
        {
          "type": "formula",
          "expr": "datum.HalfStepCount > 15 ? 1 : 0.5",
          "as": "TickStep"
        },
        {
          "type": "formula",
          "expr": "ceil(datum.DomainMin / datum.TickStep) * datum.TickStep",
          "as": "FirstTick"
        },
        {
          "type": "formula",
          "expr": "sequence(datum.FirstTick, datum.DomainMax + datum.TickStep * 0.5, datum.TickStep)",
          "as": "TickArray"
        },
        {
          "type": "flatten",
          "fields": [
            "TickArray"
          ],
          "as": [
            "Value"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.Value >= datum.DomainMin && datum.Value <= datum.DomainMax"
        },
        {
          "type": "formula",
          "expr": "datum.TickStep >= 1 ? format(datum.Value, '.0f') : format(datum.Value, '.1f')",
          "as": "Label"
        }
      ]
    },
    {
      "name": "hundredTick",
      "source": "yDomain",
      "transform": [
        {
          "type": "filter",
          "expr": "datum.DomainMin <= 100 && datum.DomainMax >= 100"
        },
        {
          "type": "formula",
          "expr": "100",
          "as": "Value"
        },
        {
          "type": "formula",
          "expr": "'100'",
          "as": "Label"
        }
      ]
    }
  ],
