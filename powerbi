  "height": 900,
  "padding": 0,
  "autosize": {
    "type": "fit",
    "contains": "padding",
    "resize": true
  },
  "signals": [
    {
      "name": "selectedCompany",
      "value": "AIA Thailand",
      "bind": {
        "name": "Company: ",
        "input": "select",
        "options": [
          "AIA Thailand",
          "SCB Life",
          "Muang Thai Life"
        ]
      }
    },
    {
      "name": "selectedProduct",
      "value": "AIA S&P 500 Linked",
      "bind": {
        "name": "Product: ",
        "input": "select",
        "options": [
          "AIA S&P 500 Linked",
          "AIA Hang Seng Linked",
          "SCB NASDAQ 100 Linked",
          "SCB Nikkei 225 Linked",
          "MT Euro Stoxx 50 Linked"
        ]
      },
      "on": [
        {
          "events": {
            "signal": "selectedCompany"
          },
          "update": "selectedCompany === 'AIA Thailand' ? 'AIA S&P 500 Linked' : selectedCompany === 'SCB Life' ? 'SCB NASDAQ 100 Linked' : 'MT Euro Stoxx 50 Linked'"
        }
      ]
    },
    {
      "name": "selectedCohort",
      "value": 1,
      "bind": {
        "name": "Cohort: ",
        "input": "select",
        "options": [
          1,
          2,
          3
        ],
        "labels": [
          "Cohort 1",
          "Cohort 2",
          "Cohort 3"
        ]
      },
      "on": [
        {
          "events": {
            "signal": "selectedProduct"
          },
          "update": "1"
        }
      ]
    }
  ],
  "data": [
    {
      "name": "dataset"
    },
    {
      "name": "validData",
      "source": "dataset",
      "transform": [
        {
          "type": "formula",
          "expr": "toDate(datum.Date)",
          "as": "ParsedDate"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.Price)",
          "as": "NumericPrice"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.CohortNo)",
          "as": "NumericCohort"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.IndexBaseValue)",
          "as": "NumericBase"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.ParticipationRate)",
          "as": "NumericParticipation"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.CapRate)",
          "as": "NumericCap"
        },
        {
          "type": "formula",
          "expr": "toNumber(datum.FloorRate)",
          "as": "NumericFloor"
        },
        {
          "type": "filter",
          "expr": "isValid(datum.ParsedDate) && isFinite(datum.NumericPrice) && datum.Company === selectedCompany && datum.ProductName === selectedProduct && datum.NumericCohort === selectedCohort"
        },
        {
          "type": "formula",
          "expr": "datum.NumericBase > 0 ? datum.NumericPrice / datum.NumericBase * 100 : 100",
          "as": "DisplayIndex"
        },
        {
          "type": "formula",
          "expr": "datum.NumericBase > 0 ? datum.NumericPrice / datum.NumericBase - 1 : 0",
          "as": "DisplayRawReturn"
        },
        {
          "type": "formula",
          "expr": "100 * (1 + min(max(datum.DisplayRawReturn * datum.NumericParticipation, datum.NumericFloor), datum.NumericCap))",
          "as": "DisplayProduct"
        },
        {
          "type": "collect",
          "sort": {
            "field": "ParsedDate",
            "order": "ascending"
          }
        }
      ]
    },
    {
      "name": "latest",
      "source": "validData",
      "transform": [
        {
          "type": "collect",
          "sort": {
            "field": "ParsedDate",
            "order": "descending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "rowNumber"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.rowNumber === 1"
        }
      ]
    },
    {
      "name": "summary",
      "source": "validData",
      "transform": [
        {
          "type": "aggregate",
          "ops": [
            "max",
            "min",
            "max",
            "min"
          ],
          "fields": [
            "IndexNormalized",
            "IndexNormalized",
            "ProductValue",
            "ProductValue"
          ],
          "as": [
            "MaxIndex",
            "MinIndex",
            "MaxProduct",
            "MinProduct"
          ]
        }
      ]
    }
