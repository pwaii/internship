{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "AIA dark product viewer dashboard for index-linked insurance.",
  "background": "#071120",
  "autosize": {
    "type": "pad",
    "contains": "padding",
    "resize": true
  },
  "padding": 0,
  "data": {
    "name": "dataset"
  },
  "transform": [
    {
      "filter": "isValid(datum['Date']) && isValid(datum['Price'])"
    },
    {
      "joinaggregate": [
        {
          "op": "min",
          "field": "Date",
          "as": "FirstDate"
        },
        {
          "op": "max",
          "field": "Date",
          "as": "LastDate"
        },
        {
          "op": "mean",
          "field": "ParticipationRate",
          "as": "Participation"
        },
        {
          "op": "mean",
          "field": "CapRate",
          "as": "Cap"
        },
        {
          "op": "mean",
          "field": "FloorRate",
          "as": "Floor"
        },
        {
          "op": "mean",
          "field": "IndexBaseValue",
          "as": "BaseValue"
        }
      ],
      "groupby": [
        "Company",
        "ProductName",
        "IndexName",
        "Currency",
        "CohortNo"
      ]
    },
    {
      "window": [
        {
          "op": "first_value",
          "field": "Price",
          "as": "FirstPrice"
        },
        {
          "op": "last_value",
          "field": "Price",
          "as": "LastPrice"
        },
        {
          "op": "min",
          "field": "Price",
          "as": "MinPrice"
        },
        {
          "op": "max",
          "field": "Price",
          "as": "MaxPrice"
        }
      ],
      "sort": [
        {
          "field": "Date",
          "order": "ascending"
        }
      ],
      "groupby": [
        "Company",
        "ProductName",
        "IndexName",
        "Currency",
        "CohortNo"
      ]
    },
    {
      "calculate": "datum.Price / datum.FirstPrice * 100",
      "as": "IndexNormalized"
    },
    {
      "calculate": "(datum.Price / datum.BaseValue - 1)",
      "as": "RawIndexReturn"
    },
    {
      "calculate": "datum.RawIndexReturn * datum.Participation",
      "as": "ParticipatedReturn"
    },
    {
      "calculate": "min(max(datum.ParticipatedReturn, datum.Floor), datum.Cap)",
      "as": "CreditedReturn"
    },
    {
      "calculate": "100 * (1 + datum.CreditedReturn)",
      "as": "ProductValue"
    },
    {
      "calculate": "(datum.LastPrice / datum.FirstPrice - 1)",
      "as": "IndexReturnToday"
    },
    {
      "calculate": "min(max((datum.LastPrice / datum.BaseValue - 1) * datum.Participation, datum.Floor), datum.Cap)",
      "as": "ProductReturnToday"
    },
    {
      "calculate": "(datum.MaxPrice / datum.BaseValue - 1) * datum.Participation",
      "as": "MaxRawUpside"
    },
    {
      "calculate": "min(max(datum.MaxRawUpside, datum.Floor), datum.Cap)",
      "as": "MaxUpside"
    },
    {
      "calculate": "min(0, (datum.MinPrice / datum.BaseValue - 1) * datum.Participation)",
      "as": "MaxDrawdown"
    },
    {
      "calculate": "datum['Company'] || 'AIA Thailand'",
      "as": "SelectedCompany"
    },
    {
      "calculate": "datum['ProductName'] || 'AIA S&P 500 Linked'",
      "as": "SelectedProduct"
    },
    {
      "calculate": "'Cohort ' + datum['CohortNo']",
      "as": "SelectedCohort"
    }
