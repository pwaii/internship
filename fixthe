  body.getFormat().setWrapText(false);
  body.getFormat().setHorizontalAlignment(ExcelScript.HorizontalAlignment.left);
  body.getFormat().setVerticalAlignment(ExcelScript.VerticalAlignment.top);
  body.getFormat().setRowHeight(24);
  applySetupGridBorders(body, border);

  sheet.getRange("Q1:V1").getFormat().getFill().setColor(burgundy);
  sheet.getRange("Q1:V1").getFormat().getFont().setColor(white);
  sheet.getRange("Q1:V1").getFormat().getFont().setBold(true);
  sheet.getRange("Q3:V3").getFormat().getFill().setColor(black);
  sheet.getRange("Q3:V3").getFormat().getFont().setColor(white);
  sheet.getRange("Q3:V3").getFormat().getFont().setBold(true);
  sheet.getRange("Q4:V500").getFormat().getFill().setColor(white);
  sheet.getRange("Q4:V500").getFormat().setWrapText(false);
  sheet.getRange("Q4:V500").getFormat().setHorizontalAlignment(ExcelScript.HorizontalAlignment.left);
  sheet.getRange("Q4:V500").getFormat().setVerticalAlignment(ExcelScript.VerticalAlignment.top);
  sheet.getRange("D2:E2").getFormat().getFill().setColor(darkGray);
  sheet.getRange("D2:E2").getFormat().getFont().setColor(white);
  sheet.getRange("D2:E2").getFormat().getFont().setBold(true);
  sheet.getRange("D3:E3").getFormat().getFill().setColor(black);
  sheet.getRange("D3:E3").getFormat().getFont().setColor(white);
  sheet.getRange("D3:E3").getFormat().getFont().setBold(true);
  sheet.getRange("D4:E7").getFormat().getFill().setColor(white);
