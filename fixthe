/**
 * Excel Pivot Builder - single-workbook Office Script.
 *
 * Run this script inside the raw-data workbook.
 * First run creates PivotBuilder_Setup. Later runs refresh fields and build pivots
 * directly in the same workbook. No Power Automate flow is required.
 */

const SETUP_SHEET = "PivotBuilder_Setup";
const SOURCE_SHEET = "__PivotSource";
const SOURCE_SHEET_PREFIX = "__PivotSource_";
const FIRST_SETUP_ROW = 9;
const LAST_SETUP_ROW = 200;
const OUTPUT_ROW_LABEL_COLUMN_WIDTH = 105;
const OUTPUT_VALUE_COLUMN_WIDTH = 72;
const OUTPUT_DESCRIPTION_COLUMNS = 4;
const OUTPUT_DESCRIPTION_COLUMN_WIDTH = 58;
const OUTPUT_SPACER_ROWS_WITH_FILTERS = 2;
const OUTPUT_SPACER_ROWS_WITHOUT_FILTERS = 1;
const OUTPUT_NEXT_RIGHT_GAP_COLUMNS = 4;
const OUTPUT_NEXT_DOWN_GAP_ROWS = 2;
const EXCEL_MAX_ROWS = 1048576;
const EXCEL_MAX_COLUMNS = 16384;
const MAX_RUN_SECONDS = 240;
const CONTROLLED_STOP_PREFIX = "CONTROLLED_STOP:";
const RESUME_KEY_CELL = "Z5";
const RESUME_ROW_CELL = "Z6";
const BUILD_SIGNATURE_COLUMN = "AA";
const BUILD_SOURCE_MARKER_COLUMN = "AB";
const MONTH_NAMES = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

type CellValue = string | number | boolean;

// Embedded templates are installed once in each workbook. Edit the workbook rows
// freely afterward; normal runs never overwrite them. Change this block only when
// you want new workbooks to receive different organization-wide defaults.
const EMBEDDED_TEMPLATE_VERSION = "PB_EMBEDDED_1";
const SETUP_SCHEMA_VERSION = "PB_SCHEMA_4";
const SETUP_STYLE_VERSION = "PB_STYLE_12";
const EMBEDDED_TEMPLATE_ROWS: CellValue[][] = [
  [
    "", "Default", "Pivot 1", "Pivot_Output", "", "", "",
    "", "", "", "No", "Choose fields from the dropdowns, then run Build pivots.",
    "Replace previous outputs", "", ""
  ]
];

interface PivotSetup {
  inputSheet: string;
  template: string;
  pivotName: string;
  outputSheet: string;
  replaceOutput: boolean;
  rows: string;
  rowNames: string;
  calculations: string;
  values: string;
  filters: string;
  conditions: string;
  nextRight: boolean;
  sourceRow: number;
}

interface FieldCondition {
  field: string;
  values: string[];
  rawValue: string;
  compareField?: string;
  matchMode?: "all" | "any";
  subconditions?: FieldCondition[];
  measureField?: string;
  caption?: string;
}

interface CustomRowRule {
  label: string;
  conditions: FieldCondition[];
}

interface CalculationSpec {
  label: string;
  terms: CalculationTerm[];
}

interface CalculationTerm {
  operator: string;
  reference: string;
}

interface ComparisonExpression {
  left: string;
  operator: string;
  right: string;
}

interface IfExpression {
  condition: string;
  whenTrue: string;
  whenFalse: string;
}

interface PivotLookup {
  sheetName?: string;
  pivotName: string;
  rowLabel: string;
  columnLabel: string;
  allRows: boolean;
}

interface BuiltPivot {
  inputName: string;
  actualName: string;
  outputAlias: string;
  sheetName: string;
  rangeRow: number;
  rangeColumn: number;
  values: CellValue[][];
}

interface PendingCalculatedOutput {
  sheetName: string;
  pivotInputName: string;
  pivotActualName: string;
  setup: PreparedPivotSetup;
  rowCaptions: string[];
  rowColumnCount: number;
}

interface LocatedPivotRange {
  sheetName: string;
  rangeRow: number;
  rangeColumn: number;
  rangeRowCount: number;
  rangeColumnCount: number;
  values: CellValue[][];
}

interface Placement {
  row: number;
  col: number;
  bandBottom: number;
}

interface OccupiedBlock {
  top: number;
  left: number;
  bottom: number;
  right: number;
}

interface SourceModel {
  sourceSheetName: string;
  sourceAddress: string;
  headers: string[];
  parseHeaders: string[];
  baseHeaders: string[];
  helperByKey: Map<string, string>;
  numericByHeader: Map<string, boolean>;
}

interface PreparedPivotSetup extends PivotSetup {
  rowFieldsParsed: string[];
  rowNamesParsed: string[];
  valueFieldsParsed: string[];
  effectiveValueFieldsParsed: string[];
  filtersParsed: FieldCondition[];
  conditionsParsed: FieldCondition[];
  calculationSpecsParsed: CalculationSpec[];
  customRowRulesParsed: (CustomRowRule | undefined)[];
  hasCustomRowRule: boolean;
  requiresPreparedSource: boolean;
}

interface PendingBuildItem {
  setup: PreparedPivotSetup;
  source: SourceModel;
  sourceMarker: string;
}

interface RawAppendResult {
  updatedColumns: number;
  processedRows: number;
}

const splitListCache = new Map<string, string[]>();
const splitSemicolonCache = new Map<string, string[]>();
const filterSpecCache = new Map<string, FieldCondition[]>();
const conditionCache = new Map<string, FieldCondition[]>();
const calculationSpecCache = new Map<string, CalculationSpec[]>();
const pivotRangeCache = new Map<string, LocatedPivotRange>();
const pivotLookupAddressCache = new Map<string, string>();
const sheetPivotNamesCache = new Map<string, string[]>();

function main(workbook: ExcelScript.Workbook): string {
  clearRuntimeCaches();
  let setup = workbook.getWorksheet(SETUP_SHEET);
  if (!setup) {
    setup = createSetupSheet(workbook);
    writeStatus(setup, "Setup created. Choose an Input Sheet in row 9, complete the row, then run this script again.");
    return "";
  }

  try {
    ensureCurrentSetupSchema(workbook, setup);
    ensureEmbeddedTemplatesSeeded(setup);
    if (text(setup.getRange("Z2").getValue()) !== SETUP_STYLE_VERSION) {
      applySetupStyle(setup);
    } else {
      resetSetupErrorStyle(setup);
    }

    const action = text(setup.getRange("B4").getValue());
    const selectedTemplateInput = text(setup.getRange("B3").getValue()) || "All";
    if (equalsText(action, "Restore starter template") || equalsText(action, "Restore embedded templates")) {
      clearResumeState(setup);
      restoreEmbeddedTemplates(setup);
      refreshCloudSetup(workbook, setup);
      setup.getRange("B4").setValue("Build pivots");
      writeStatus(setup, "Embedded templates restored. Edit the setup rows normally; later builds will preserve your changes.");
      return "";
    }
    if (
      equalsText(action, "Refresh fields") ||
      equalsText(action, "Refresh fields only") ||
      equalsText(action, "Refresh template") ||
      equalsText(action, "Refresh setup") ||
      equalsText(action, "Refresh layout")
    ) {
      clearResumeState(setup);
      refreshCloudSetup(workbook, setup);
      writeStatus(setup, "Fields, worksheets, and template choices refreshed.");
      return "";
    }

    const selectedTemplates = applyMonthlyInputs(selectedTemplateInput, readMonthlyInputs(setup));

    const sourceStarted = Date.now();
    const allSetups = readSetups(setup);
    const selectedBuilds = allSetups.filter(row => templateSelected(row.template, selectedTemplates));
    const resumeKey = buildResumeKey(selectedBuilds, selectedTemplates);
    const builds = applyResumeState(setup, selectedBuilds, resumeKey);
    if (builds.length === 0) throw new Error(`No PivotTable rows match template/group selection: ${selectedTemplates}`);

    const autoRawBuilds = builds.filter(row => outputMatchesInput(row));
    const pivotBuilds = builds.filter(row => !outputMatchesInput(row));

    let autoRawResult: RawAppendResult = { updatedColumns: 0, processedRows: 0 };
    if (autoRawBuilds.length > 0) {
      writeStatus(setup, `Appending raw columns for ${autoRawBuilds.length} setup row(s) where Input Sheet matches Output Sheet...`);
      autoRawResult = appendRawColumnsForSetups(workbook, setup, autoRawBuilds, "Auto raw append");
    }

    if (pivotBuilds.length === 0) {
      clearResumeState(setup);
      writeStatus(setup, `Finished. Raw append updated ${autoRawResult.updatedColumns} column(s) across ${autoRawResult.processedRows} setup row(s).`);
      return JSON.stringify({ rawUpdatedColumns: autoRawResult.updatedColumns, rawRows: autoRawResult.processedRows, built: 0, skipped: 0 });
    }

    writeStatus(setup, `Preparing source data for ${pivotBuilds.length} PivotTable(s)...`);
    const groupedBuilds = groupSetupsByInputSheet(pivotBuilds);
    const pendingItems: PendingBuildItem[] = [];
    let totalSkipped = 0;

    groupedBuilds.forEach(group => {
      const dataSheet = findWorksheetByName(workbook, group.inputSheet);
      if (!dataSheet) throw new Error(`Data sheet not found: ${group.inputSheet}`);
      if (dataSheet.getName() === SETUP_SHEET || isHelperSourceSheet(dataSheet.getName())) {
        throw new Error(`Choose a normal data sheet in setup rows, not the setup/helper sheet: ${group.inputSheet}`);
      }

      const used = dataSheet.getUsedRange(true);
      if (!used) throw new Error(`Data sheet '${dataSheet.getName()}' is empty.`);
      const rawHeaders = readRawHeaderRow(used);
      const headers = normalizeHeaders(rawHeaders);
      const preparedBuilds = prepareSetups(group.setups, headers);
      const sourceMarker = buildSourceMarker(dataSheet, used, headers);
      const pendingBuilds = preparedBuilds.filter(item => !shouldSkipUnchangedTable(workbook, item, sourceMarker));
      totalSkipped += preparedBuilds.length - pendingBuilds.length;
      if (pendingBuilds.length === 0) return;

      const rawNeedsNormalization = headersNeedNormalizationFromRaw(rawHeaders);
      if (rawNeedsNormalization) {
        const source = buildNormalizedSource(
          workbook,
          dataSheet,
          used,
          headers,
          pendingBuilds,
          helperSourceSheetName(dataSheet.getName())
        );
        pendingBuilds.forEach(item => pendingItems.push({ setup: item, source, sourceMarker }));
        return;
      }

      const requiresPreparedSource = pendingBuilds.some(item => item.requiresPreparedSource);
      if (requiresPreparedSource) {
        const normalizedSource = buildNormalizedSource(
          workbook,
          dataSheet,
          used,
          headers,
          pendingBuilds,
          helperSourceSheetName(dataSheet.getName())
        );
        pendingBuilds.forEach(item => pendingItems.push({ setup: item, source: normalizedSource, sourceMarker }));
        return;
      }

      const directSource = buildDirectSource(dataSheet, used, headers, pendingBuilds);
      pendingBuilds.forEach(item => pendingItems.push({ setup: item, source: directSource, sourceMarker }));
    });

    if (pendingItems.length === 0) {
      clearResumeState(setup);
      writeStatus(setup, `All selected tables are unchanged. Nothing to build.`);
      return JSON.stringify({ skipped: totalSkipped });
    }
    const sourceSeconds = (Date.now() - sourceStarted) / 1000;
    const pivotStarted = Date.now();
    buildAllPivots(workbook, setup, pendingItems, Date.now(), resumeKey);
    clearResumeState(setup);
    const pivotSeconds = (Date.now() - pivotStarted) / 1000;
    hideHelperSourceSheets(workbook);

    writeStatus(
      setup,
      `Finished: ${pendingItems.length} PivotTable(s)` +
      `${totalSkipped > 0 ? `, skipped ${totalSkipped}` : ""}. ` +
      `${autoRawResult.processedRows > 0 ? ` Raw append rows ${autoRawResult.processedRows}, columns updated ${autoRawResult.updatedColumns}.` : ""} ` +
      `Source ${sourceSeconds.toFixed(1)}s; Pivot build ${pivotSeconds.toFixed(1)}s.`
    );
    return JSON.stringify({ built: pendingItems.length, skipped: totalSkipped, rawUpdatedColumns: autoRawResult.updatedColumns, rawRows: autoRawResult.processedRows });
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    if (!message.startsWith(CONTROLLED_STOP_PREFIX)) clearResumeState(setup);
    flagSetupError(setup, message);
    writeStatus(setup, message.startsWith(CONTROLLED_STOP_PREFIX) ? message.slice(CONTROLLED_STOP_PREFIX.length).trim() : `ERROR: ${message}`);
    throw error;
  }
}

function clearRuntimeCaches() {
  pivotRangeCache.clear();
  pivotLookupAddressCache.clear();
  sheetPivotNamesCache.clear();
}

function headerPayloadJson(dataSheet: ExcelScript.Worksheet): string {
  const used = dataSheet.getUsedRange(true);
  if (!used || used.getRowCount() < 1 || used.getColumnCount() < 1) {
    throw new Error(`Input data sheet has no header row: ${dataSheet.getName()}`);
  }
  const headers = readHeaderRow(used);
  return JSON.stringify({ dataSheet: dataSheet.getName(), headers });
}

function createSetupSheet(workbook: ExcelScript.Workbook): ExcelScript.Worksheet {
  const existing = workbook.getWorksheet(SETUP_SHEET);
  if (existing) return existing;
  const sheet = workbook.addWorksheet(SETUP_SHEET);
  sheet.setShowGridlines(false);

  sheet.getRange("A1:O1").merge(false);
  sheet.getRange("A1").setValue("Excel Pivot Builder");
  sheet.getRange("A3").setValue("Selected template");
  sheet.getRange("A4").setValue("Action");
  sheet.getRange("A6").setValue("Status");
  sheet.getRange("B3").setValue("All");
  sheet.getRange("B4").setValue("Build pivots");
  sheet.getRange("B6:O6").merge(false);

  sheet.getRange("A8:O8").setValues([[
    "Input Sheet", "Template", "Pivot Name", "Output Sheet", "Rows", "Row Names", "Calculated Columns",
    "Values To Count/Sum", "Filters", "Conditions", "Next Pivot Right", "Notes",
    "Output Behavior", "", ""
  ]]);
  seedMissingEmbeddedTemplates(sheet);
  if (!text(sheet.getRange(`A${FIRST_SETUP_ROW}`).getValue())) sheet.getRange(`A${FIRST_SETUP_ROW}`).setValue(firstDataSheetName(workbook));
  sheet.getRange("Z1").setValue(EMBEDDED_TEMPLATE_VERSION);
  sheet.getRange("Z4").setValue(SETUP_SCHEMA_VERSION);

  sheet.getRange("Q1:V1").merge(false);
  sheet.getRange("Q1").setValue("Suggestions");
  sheet.getRange("Q3").setValue("Available Fields");
  sheet.getRange("T3").setValue("Template Choices");
  sheet.getRange("U3").setValue("Sheet Choices");
  sheet.getRange("V3").setValue("Output Sheet Choices");
  sheet.getRange(`${BUILD_SIGNATURE_COLUMN}8`).setValue("Build Signature");
  sheet.getRange(`${BUILD_SOURCE_MARKER_COLUMN}8`).setValue("Build Source Marker");
  seedMonthlyInputs(sheet);

  applySetupStyle(sheet);
  refreshCloudSetup(workbook, sheet);
  return sheet;
}

